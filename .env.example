# Database (Aiven MySQL) - replace with your own values
DB_HOST=your-mysql-host.aivencloud.com
DB_PORT=26578
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=defaultdb

# Auth - use a long random string in production
JWT_SECRET=replace_this_with_a_secure_random_string
JWT_EXPIRES_IN=7d

# TMDB API - get your key from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Frontend origin for CORS (e.g. http://localhost:5173 or your Vercel URL)
CLIENT_URL=http://localhost:5173
PORT=5000
